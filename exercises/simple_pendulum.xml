<mujoco model="simple_pendulum">
  <option gravity="0 0 -9.81" timestep="0.01"/>

  <worldbody>
    <geom name="floor" type="plane" size="2 2 0.1" rgba="0.9 0.9 0.9 1"/>

    <body name="base" pos="0 0 0">
      <geom name="base_geom" type="box" size="0.05 0.05 0.05" rgba="0.2 0.2 0.2 1"/>

      <body name="pendulum" pos="0 0 0.05">
        <joint
          name="hinge"
          type="hinge"
          axis="0 1 0"
          pos="0 0 0"
          range="-90 90"
          damping="0.1"/>

        <geom
          name="rod"
          type="capsule"
          fromto="0 0 0 0 0 -0.5"
          size="0.03"
          density="600"
          rgba="0.2 0.5 0.9 1"/>

        <site
          name="tip"
          pos="0 0 -0.5"
          size="0.025"
          rgba="1 0.2 0.2 1"/>
      </body>
    </body>
  </worldbody>

  <actuator>
    <motor name="hinge_motor" joint="hinge" gear="20" ctrlrange="-1 1"/>
  </actuator>
</mujoco>
